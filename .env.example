#--------------------------------------------------------------------
# AleKarting — Plantilla de configuración (.env.example)
#
# Copia este archivo a `.env` y rellena los valores reales.
# El archivo `.env` NUNCA debe subirse al repositorio (está en .gitignore).
#--------------------------------------------------------------------

# ENVIRONMENT
CI_ENVIRONMENT = development

# JWT — usa una cadena aleatoria larga (mínimo 32 caracteres)
JWT_SECRET = 'cambiame_por_una_clave_aleatoria_larga'

# APP
# app.baseURL = 'http://localhost:8080/'

# DATABASE
database.default.hostname = localhost
database.default.database = alekarting
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# STRIPE — claves de tu cuenta (modo test para desarrollo)
# Obténlas en https://dashboard.stripe.com/test/apikeys
# Formato real: las claves empiezan por pk_test_... y sk_test_...
STRIPE_PUBLISHABLE_KEY = 'TU_CLAVE_PUBLICABLE_AQUI'
STRIPE_SECRET_KEY      = 'TU_CLAVE_SECRETA_AQUI'
